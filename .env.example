# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- API ---
API_PORT=4000
API_PUBLIC_URL=http://localhost:4000

# --- Midtrans (payments) ---
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# --- GoSend (Gojek Logistics API) ---
# Sign up: https://api-docs.gojek.com (Gojek for Business / Logistics partner)
GOSEND_CLIENT_ID=
GOSEND_PASS_KEY=
GOSEND_BASE_URL=https://integration-merchant-api.gojek.co.id

# --- Grab Express ---
# Sign up: https://developer.grab.com (Grab Express API)
GRAB_CLIENT_ID=
GRAB_CLIENT_SECRET=
GRAB_BASE_URL=https://partner-api.grab.com

# --- Sourcing / Search ---
SCRAPER_USER_AGENT="GoGetBot/1.0 (+https://goget.id/bot)"
SCRAPER_RATE_LIMIT_MS=1500

# --- Anthropic / AI hardening ---
ANTHROPIC_API_KEY=
# --- Apify fallback image extraction ---
APIFY_TOKEN=
# Optional override (defaults to skipper_lume/ecommerce-product-scraper in code)
APIFY_IMAGE_ACTOR_ID=
# Optional API base override (defaults to https://api.apify.com/v2)
APIFY_API_BASE_URL=
# Global switch for expensive AI sourcing routes (defaults to false in production).
AI_EXPENSIVE_SOURCING_ENABLED=true
# Per-route overrides (set to true/false explicitly if you want hard route-level control).
AI_ROUTE_SOURCING_TEST_ENABLED=true
AI_ROUTE_SOURCING_WEB_ENABLED=true
AI_ROUTE_SEARCH_REFINE_ENABLED=true
# Per-route budget/timeouts/caching.
AI_ROUTE_SOURCING_TEST_BUDGET_USD=0.02
AI_ROUTE_SOURCING_TEST_TIMEOUT_MS=6500
AI_ROUTE_SOURCING_TEST_RESULT_CACHE_TTL_MS=180000
AI_ROUTE_SOURCING_TEST_PROMPT_CACHE_TTL=1h
AI_ROUTE_SOURCING_WEB_BUDGET_USD=0.03
AI_ROUTE_SOURCING_WEB_TIMEOUT_MS=12000
AI_ROUTE_SOURCING_WEB_RESULT_CACHE_TTL_MS=120000
AI_ROUTE_SOURCING_WEB_PROMPT_CACHE_TTL=5m
AI_ROUTE_SOURCING_WEB_MAX_USES=4
AI_ROUTE_SEARCH_REFINE_BUDGET_USD=0.005
AI_ROUTE_SEARCH_REFINE_TIMEOUT_MS=3500
AI_ROUTE_SEARCH_REFINE_RESULT_CACHE_TTL_MS=900000
AI_ROUTE_SEARCH_REFINE_PROMPT_CACHE_TTL=1h

# --- Web app ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Mobile app ---
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_API_URL=http://localhost:4000
